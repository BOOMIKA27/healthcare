service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: patients
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required)
    //   - fullName: string (required, 1-100 chars)
    //   - age: number (optional, 0-120)
    //   - gender: string (optional, enum)
    //   - location: string (optional, 0-200 chars)
    //   - language: string (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: diagnoses
    // Document ID: {diagnosisId}
    // Fields:
    //   - patientId: string (required, matches auth.uid)
    //   - symptoms: string (required, 1-5000 chars)
    //   - imageUrls: list (optional, max 5)
    //   - vitals: map (optional)
    //   - aiAnalysis: string (required)
    //   - triageLevel: string (required, enum)
    //   - language: string (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: alerts
    // Document ID: {alertId}
    // Fields:
    //   - diagnosisId: string (required)
    //   - patientId: string (required)
    //   - location: string (required)
    //   - status: string (required, enum)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/patients/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "boomika4225@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidPatient(data) {
      return data.keys().hasAll(['uid', 'fullName', 'language', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.fullName is string && data.fullName.size() > 0 && data.fullName.size() <= 100 &&
             data.language is string &&
             data.createdAt is timestamp;
    }

    function isValidDiagnosis(data) {
      return data.keys().hasAll(['patientId', 'symptoms', 'aiAnalysis', 'triageLevel', 'language', 'createdAt']) &&
             data.patientId == request.auth.uid &&
             data.symptoms is string && data.symptoms.size() > 0 && data.symptoms.size() <= 5000 &&
             data.triageLevel in ['emergency', 'urgent', 'routine'] &&
             data.createdAt is timestamp;
    }

    match /patients/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid) && isValidPatient(request.resource.data);
      allow update: if isOwner(uid) && isValidPatient(request.resource.data) && 
                    request.resource.data.createdAt == resource.data.createdAt;
    }

    match /diagnoses/{diagnosisId} {
      allow read: if isAuthenticated() && (resource.data.patientId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidDiagnosis(request.resource.data);
      allow update: if isAdmin() && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['doctorVerification']) &&
                    request.resource.data.doctorVerification.status in ['verified', 'rejected'];
    }

    match /doctors/{uid} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /appointments/{appointmentId} {
      allow read: if isAuthenticated() && (resource.data.patientId == request.auth.uid || resource.data.doctorId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.patientId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.doctorId == request.auth.uid || isAdmin());
    }

    match /alerts/{alertId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && request.resource.data.patientId == request.auth.uid;
      allow update: if isAdmin();
    }
  }
}
